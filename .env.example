# App
APP_NAME=CMS Platform
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://cms_user:postgres@localhost:5435/cms_db
DATABASE_SYNC_URL=postgresql://cms_user:postgres@localhost:5435/cms_db

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://cms_user:cms_password@localhost:5672/

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8081"]

# First superadmin (seeded on startup)
FIRST_SUPERADMIN_EMAIL=admin@cms.com
FIRST_SUPERADMIN_PASSWORD=Admin@123456
